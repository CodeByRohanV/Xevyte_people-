# # -----------------------------------
# # FRONTEND CONFIG (.env)
# # -----------------------------------
 
# # Port on which HRMS frontend runs (Scaloz Tenant UI runs on 3001)
# PORT=3000
 
# # Disable source maps to hide code in browser DevTools
# GENERATE_SOURCEMAP=false
 
# # Base URL of HRMS backend API
# REACT_APP_API_BASE_URL=https://hrmstest.scaloz.com/api
 
# # App environment (optional)
# REACT_APP_ENV=production
 
# # Application name (optional)
# REACT_APP_NAME=XevyteHub HRMS
 
# # OpenStreetMap API key for address autocomplete
# REACT_APP_OPENSTREETMAP_API_KEY=your_openstreetmap_api_key_here
 
# # External/Public API Key for bypass
# REACT_APP_EXTERNAL_API_KEY=xevyte_secure_api_key_2026_prod_v1
 
# # ==== SSO — Scaloz IAM Integration ====
# # Scaloz Tenant Login UI URL (the IAM login page)
# REACT_APP_IAM_URL=https://workspacetest.scaloz.com
# # This app's own URL (used in redirect_to param when bouncing to IAM)
# REACT_APP_HRMS_URL=https://hrmstest.scaloz.com



# -----------------------------------
 
# FRONTEND CONFIG (.env)
 
# -----------------------------------
 
PORT=3000
 
  
 
# Disable source maps to hide code in browser DevTools
 
GENERATE_SOURCEMAP=false
 
  
 
# Base URL of HRMS backend API
 
REACT_APP_API_BASE_URL=http://127.0.0.1:8082/api
 
  
 
# App environment
 
REACT_APP_ENV=development
 
  
 
# Application name (optional)
 
REACT_APP_NAME=Scaloz Hrms
 
  
 
# OpenStreetMap API key for address autocomplete
 
REACT_APP_OPENSTREETMAP_API_KEY=your_openstreetmap_api_key_here
  
REACT_APP_IAM_URL=http://localhost:3001
REACT_APP_HRMS_URL=http://localhost:3000