import React, { useState, useEffect, useRef } from 'react';
import api from '../api';
import { FiSettings, FiTrash2, FiPlus, FiFileText, FiUser, FiDollarSign, FiTag } from 'react-icons/fi';
import mammoth from 'mammoth';
import SalaryStructureManagement from './SalaryStructureManagement';

const CompensationSettings = () => {
    const [activeTab, setActiveTab] = useState('salaryStructure');
    const [templates, setTemplates] = useState([]);
    const [revisionTypes, setRevisionTypes] = useState([]);
    const [salaryComponents, setSalaryComponents] = useState([]);
    const [designationCategories, setDesignationCategories] = useState([]);
    const [newRevisionTypeName, setNewRevisionTypeName] = useState('');
    const [newTemplateFile, setNewTemplateFile] = useState(null);
    const templateFileRef = useRef(null);
    const [newDesignationCategory, setNewDesignationCategory] = useState('');
    const [isSettingsLoading, setIsSettingsLoading] = useState(false);
    const [isAddingDesignation, setIsAddingDesignation] = useState(false);
        const [editingComponent, setEditingComponent] = useState(null);
    const [previewModal, setPreviewModal] = useState({ isOpen: false, template: null, fileUrl: null });
    const [documentContent, setDocumentContent] = useState(null);
    const [isDocumentLoading, setIsDocumentLoading] = useState(false);
    const [newComponent, setNewComponent] = useState({
        name: '',
        placeholder: '',
        type: 'EARNING',
        calculationType: 'FORMULA',
        calculationValue: '',
        formula: '',
        sourceComponent: '',
        section: 'Monthly Components',
        sortOrder: 1,
        isActive: true,
        showAsApplicable: false
    });

    useEffect(() => {
        fetchRevisionTypes();
        fetchTemplates();
        fetchSalaryComponents();
        fetchDesignationCategories();
    }, []);

    const fetchSalaryComponents = async () => {
        try {
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");
            const resp = await api.get('/salary-components', {
                headers: { Authorization: `Bearer ${token}` }
            });
            setSalaryComponents(resp.data);
            if (resp.data.length > 0) {
                const maxOrder = Math.max(...resp.data.map(c => c.sortOrder));
                setNewComponent(prev => ({ ...prev, sortOrder: maxOrder + 1 }));
            }
        } catch (err) {
            console.error("Salary Components fetch error:", err);
        }
    };

    const fetchTemplates = async () => {
        try {
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");
            const resp = await api.get('/compensation/templates', {
                headers: { Authorization: `Bearer ${token}` }
            });
            setTemplates(resp.data);
        } catch (err) {
            console.error("Templates fetch error:", err);
        }
    };

    const fetchRevisionTypes = async () => {
        try {
            const token = sessionStorage.getItem('token')?.replace(/^"|"$/g, "");
            const resp = await api.get('/revision-types', {
                headers: { Authorization: `Bearer ${token}` }
            });
            setRevisionTypes(resp.data);
        } catch (err) {
            console.error("Fetch Revision Types error:", err);
        }
    };

    const fetchDesignationCategories = async () => {
        try {
            // Temporary: Try API first, fallback to localStorage
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");
            const resp = await api.get('/designation-categories', {
                headers: { Authorization: `Bearer ${token}` }
            });
            setDesignationCategories(resp.data);
        } catch (err) {
            console.log("API not available, using localStorage fallback");
            // Fallback to localStorage if API is not available
            const storedCategories = localStorage.getItem('designationCategories');
            if (storedCategories) {
                setDesignationCategories(JSON.parse(storedCategories));
            }
        }
    };

    const handleAddDesignationCategory = async () => {
        if (!newDesignationCategory.trim()) {
            alert("Please enter a designation category name.");
            return;
        }

        setIsAddingDesignation(true);
        try {
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");
            const payload = {
                name: newDesignationCategory.trim()
            };

            console.log('Adding designation category with payload:', payload);

            const response = await api.post('/designation-categories', payload, {
                headers: { Authorization: `Bearer ${token}` }
            });

            console.log('Designation category added successfully:', response.data);
            setNewDesignationCategory('');
            fetchDesignationCategories();
            alert('Designation category added successfully!');
        } catch (err) {
            console.log("API not available, using localStorage fallback");
            // Fallback to localStorage if API is not available
            try {
                const storedCategories = localStorage.getItem('designationCategories');
                const categories = storedCategories ? JSON.parse(storedCategories) : [];
                const newCategory = {
                    id: Date.now(), // Simple ID generation
                    name: newDesignationCategory.trim(),
                    createdAt: new Date().toISOString()
                };
                categories.push(newCategory);
                localStorage.setItem('designationCategories', JSON.stringify(categories));
                setDesignationCategories(categories);
                setNewDesignationCategory('');
                alert('Designation category added successfully (stored locally)!');
            } catch (localErr) {
                console.error("LocalStorage fallback error:", localErr);
                alert('Failed to add designation category');
            }
        } finally {
            setIsAddingDesignation(false);
        }
    };

    const handleDeleteDesignationCategory = async (id) => {
        if (window.confirm("Are you sure you want to delete this designation category? This action cannot be undone.")) {
            await confirmDeleteDesignationCategory(id);
        }
    };

    const confirmDeleteDesignationCategory = async (id) => {
        if (!id) return;

        try {
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");

            console.log('Deleting designation category with ID:', id);

            const response = await api.delete(`/designation-categories/${id}`, {
                headers: { Authorization: `Bearer ${token}` }
            });

            console.log('Designation category deleted successfully:', response.data);
            fetchDesignationCategories();
            alert('Designation category deleted successfully!');
        } catch (err) {
            console.log("API not available, using localStorage fallback");
            // Fallback to localStorage if API is not available
            try {
                const storedCategories = localStorage.getItem('designationCategories');
                const categories = storedCategories ? JSON.parse(storedCategories) : [];
                const updatedCategories = categories.filter(cat => cat.id !== id);
                localStorage.setItem('designationCategories', JSON.stringify(updatedCategories));
                setDesignationCategories(updatedCategories);
                alert('Designation category deleted successfully (removed from local storage)!');
            } catch (localErr) {
                console.error("LocalStorage fallback error:", localErr);
                alert('Failed to delete designation category');
            }
        }
    };

    const handleCreateComponent = async () => {
        const formulaToUse = newComponent.formula || (newComponent.showAsApplicable ? '0' : '');
        if (!newComponent.name || !newComponent.type || !formulaToUse) {
            alert("Please fill required fields (Name, Type, and Formula).");
            return;
        }
        setIsSettingsLoading(true);
        try {
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");
            const payload = { ...newComponent, formula: formulaToUse };
            await api.post('/salary-components', payload, {
                headers: { Authorization: `Bearer ${token}` }
            });
            alert("Component created successfully!");
            setNewComponent({
                name: '',
                placeholder: '',
                type: 'EARNING',
                calculationType: 'FORMULA',
                calculationValue: '',
                formula: '',
                sourceComponent: '',
                section: 'Monthly Components',
                sortOrder: salaryComponents.length + 2,
                isActive: true,
                showAsApplicable: false
            });
            fetchSalaryComponents();
        } catch (err) {
            console.error("Create Component error:", err);
            alert("Failed to create component");
        } finally {
            setIsSettingsLoading(false);
        }
    };

    const handleUpdateComponent = async () => {
        const formulaToUse = editingComponent.formula || (editingComponent.showAsApplicable ? '0' : '');
        if (!editingComponent.name || !editingComponent.type || !formulaToUse) {
            alert("Please fill required fields (Name, Type, and Formula).");
            return;
        }
        setIsSettingsLoading(true);
        try {
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");
            const payload = { ...editingComponent, formula: formulaToUse };
            await api.put(`/salary-components/${editingComponent.id}`, payload, {
                headers: { Authorization: `Bearer ${token}` }
            });
            alert("Component updated successfully!");
            setEditingComponent(null);
            fetchSalaryComponents();
        } catch (err) {
            console.error("Update Component error:", err);
            alert("Failed to update component");
        } finally {
            setIsSettingsLoading(false);
        }
    };

    const handleDeleteComponent = async (id) => {
        if (!window.confirm("Are you sure you want to delete this component?")) return;
        setIsSettingsLoading(true);
        try {
            const token = sessionStorage.getItem("token")?.replace(/^"|"$/g, "");
            await api.delete(`/salary-components/${id}`, {
                headers: { Authorization: `Bearer ${token}` }
            });
            fetchSalaryComponents();
        } catch (err) {
            console.error("Delete Component error:", err);
            alert("Failed to delete component");
        } finally {
            setIsSettingsLoading(false);
        }
    };

    const handleAddRevisionType = async () => {
        if (!newRevisionTypeName.trim()) return;
        setIsSettingsLoading(true);
        try {
            const token = sessionStorage.getItem('token')?.replace(/^"|"$/g, "");
            await api.post('/revision-types', { typeName: newRevisionTypeName }, {
                headers: { Authorization: `Bearer ${token}` }
            });
            setNewRevisionTypeName('');
            fetchRevisionTypes();
        } catch (err) {
            console.error("Add Revision Type error:", err);
            alert("Failed to add revision type");
        } finally {
            setIsSettingsLoading(false);
        }
    };

    const handleDeleteRevisionType = async (id) => {
        if (!window.confirm("Are you sure you want to delete this revision type?")) return;
        setIsSettingsLoading(true);
        try {
            const token = sessionStorage.getItem('token')?.replace(/^"|"$/g, "");
            await api.delete(`/revision-types/${id}`, {
                headers: { Authorization: `Bearer ${token}` }
            });
            fetchRevisionTypes();
        } catch (err) {
            console.error("Delete Revision Type error:", err);
            alert("Failed to delete revision type");
        } finally {
            setIsSettingsLoading(false);
        }
    };

    const handleUploadTemplate = async () => {
        if (!newTemplateFile) {
            alert("Please select a file.");
            return;
        }
        setIsSettingsLoading(true);
        try {
            const token = sessionStorage.getItem('token')?.replace(/^"|"$/g, "");
            const formData = new FormData();
            formData.append('file', newTemplateFile);
            const fileName = newTemplateFile.name.replace(/\.[^/.]+$/, "");
            formData.append('name', fileName);
            formData.append('category', 'COMPENSATION');

            await api.post('/compensation/upload-template', formData, {
                headers: {
                    Authorization: `Bearer ${token}`,
                    'Content-Type': 'multipart/form-data'
                }
            });

            alert("Template uploaded successfully!");
            setNewTemplateFile(null);
            if (templateFileRef.current) templateFileRef.current.value = '';
            fetchTemplates();
        } catch (err) {
            console.error("Upload Template error:", err);
            alert("Failed to upload template");
        } finally {
            setIsSettingsLoading(false);
        }
    };

    const handleDeleteTemplate = async (id) => {
        if (!window.confirm("Are you sure you want to delete this template?")) return;
        setIsSettingsLoading(true);
        try {
            const token = sessionStorage.getItem('token')?.replace(/^"|"$/g, "");
            await api.delete(`/compensation/templates/${id}`, {
                headers: { Authorization: `Bearer ${token}` }
            });
            fetchTemplates();
        } catch (err) {
            console.error("Delete Template error:", err);
            alert("Failed to delete template");
        } finally {
            setIsSettingsLoading(false);
        }
    };

    const handlePreviewTemplate = async (templateId, templateName) => {
        try {
            const token = sessionStorage.getItem('token')?.replace(/^"|"$/g, "");
            const response = await api.get(`/compensation/templates/${templateId}/preview`, {
                headers: { Authorization: `Bearer ${token}` },
                responseType: 'arraybuffer'
            });
            
            // Create a blob URL
            const blob = new Blob([response.data], { 
                type: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' 
            });
            const fileUrl = window.URL.createObjectURL(blob);
            
            // Try to extract and render document content
            setIsDocumentLoading(true);
            setDocumentContent(null);
            
            try {
                // Convert docx to HTML with better error handling
                const htmlResult = await mammoth.convertToHtml({ 
                    arrayBuffer: response.data,
                    includeDefaultStyleMap: true,
                    styleMap: [
                        "p[style-name='Heading 1'] => h1:fresh",
                        "p[style-name='Heading 2'] => h2:fresh",
                        "p[style-name='Heading 3'] => h3:fresh",
                        "table => table.docx-table"
                    ]
                });
                
                if (htmlResult && htmlResult.value) {
                    setDocumentContent({
                        html: htmlResult.value
                    });
                } else {
                    throw new Error('No content extracted from document');
                }
            } catch (renderError) {
                console.warn('Document rendering failed, using fallback:', renderError.message);
                setDocumentContent(null);
            } finally {
                setIsDocumentLoading(false);
            }
            
            // Open modal with preview
            setPreviewModal({
                isOpen: true,
                template: { id: templateId, name: templateName },
                fileUrl: fileUrl
            });
        } catch (err) {
            console.error("Preview Template error:", err);
            setIsDocumentLoading(false);
            let errorMessage = "Failed to preview template. Please try again later.";
            if (err.response && err.response.status === 500) {
                errorMessage = "Server error occurred. Please try again or contact support.";
            } else if (err.response && err.response.status === 404) {
                errorMessage = "Template not found. It may have been deleted.";
            } else if (err.message) {
                errorMessage = `Preview failed: ${err.message}`;
            }
            alert(errorMessage);
        }
    };

    const handleClosePreviewModal = () => {
        if (previewModal.fileUrl) {
            window.URL.revokeObjectURL(previewModal.fileUrl);
        }
        setPreviewModal({ isOpen: false, template: null, fileUrl: null });
        setDocumentContent(null);
        setIsDocumentLoading(false);
    };

    // Shared Styles
    const labelStyle = { fontSize: '12px', fontWeight: '600', color: '#64748b', marginBottom: '8px', display: 'block' };
    const inputStyle = {
        width: '100%',
        paddingTop: '10px',
        paddingBottom: '10px',
        paddingLeft: '12px',
        paddingRight: '12px',
        border: '1px solid #e2e8f0',
        borderRadius: '8px',
        fontSize: '14px',
        outline: 'none',
        transition: 'border-color 0.2s',
        boxSizing: 'border-box',
        backgroundColor: '#ffffff'
    };

    const thStyle = {
        padding: '12px 16px',
        background: 'linear-gradient(135deg, #5eead4 0%, #2dd4bf 100%)',
        borderBottom: '1px solid #e2e8f0',
        color: 'white',
        fontWeight: '700',
        fontSize: '11px',
        textTransform: 'uppercase',
        letterSpacing: '0.05em',
        textAlign: 'left'
    };

    // Tab styles
    const tabContainerStyle = {
        display: 'flex',
        gap: '8px',
        borderBottom: '2px solid #f1f5f9',
        marginBottom: '24px',
        overflowX: 'auto',
        scrollbarWidth: 'thin',
        scrollbarColor: '#cbd5e1 #f1f5f9',
        WebkitOverflowScrolling: 'touch',
        msOverflowStyle: '-ms-autohiding-scrollbar'
    };

    const tabStyle = (isActive) => ({
        padding: '12px 16px',
        borderRadius: '8px 8px 0 0',
        border: 'none',
        backgroundColor: isActive ? '#0d9488' : 'transparent',
        color: isActive ? 'white' : '#64748b',
        fontSize: '13px',
        fontWeight: '600',
        cursor: 'pointer',
        transition: 'all 0.2s',
        display: 'flex',
        alignItems: 'center',
        gap: '6px',
        whiteSpace: 'nowrap',
        flexShrink: 0,
        minWidth: 'fit-content'
    });

    return (
        <>
            <style>
                {`
                    @keyframes spin {
                        0% { transform: rotate(0deg); }
                        100% { transform: rotate(360deg); }
                    }
                    .mobile-scroll {
                        overflow-x: auto;
                        -webkit-overflow-scrolling: touch;
                    }
                    .mobile-table-container {
                        overflow-x: auto;
                        -webkit-overflow-scrolling: touch;
                        margin: 0 -8px;
                        padding: 0 8px;
                    }
                    .mobile-table {
                        min-width: 600px;
                    }
                    @media (max-width: 768px) {
                        .mobile-table-container {
                            margin: 0 -12px;
                            padding: 0 12px;
                        }
                        .mobile-scroll {
                            scrollbar-width: auto;
                        }
                    }
                    /* Custom scrollbar styles */
                    ::-webkit-scrollbar {
                        width: 8px;
                        height: 8px;
                    }
                    
                    ::-webkit-scrollbar-track {
                        background: #f1f5f9;
                        border-radius: 4px;
                    }
                    
                    ::-webkit-scrollbar-thumb {
                        background: #cbd5e1;
                        border-radius: 4px;
                        border: 1px solid #e2e8f0;
                    }
                    
                    ::-webkit-scrollbar-thumb:hover {
                        background: #94a3b8;
                    }
                    
                    /* Table container specific scrollbar */
                    .mobile-table-container::-webkit-scrollbar {
                        width: 10px;
                    }
                    
                    .mobile-table-container::-webkit-scrollbar-track {
                        background: #f8fafc;
                        border-radius: 6px;
                        border: 1px solid #e2e8f0;
                    }
                    
                    .mobile-table-container::-webkit-scrollbar-thumb {
                        background: #94a3b8;
                        border-radius: 6px;
                        border: 1px solid #cbd5e1;
                    }
                    
                    .mobile-table-container::-webkit-scrollbar-thumb:hover {
                        background: #64748b;
                    }
                `}
            </style>
            <div style={{ backgroundColor: '#ffffff', minHeight: '100vh' }}>
                <div style={{
                    background: 'linear-gradient(135deg, #f0fdfa 0%, #ffffff 100%)',
                    padding: '24px 16px',
                    borderBottom: '1px solid #e2e8f0',
                    marginBottom: '24px'
                }}>
                    <h1 style={{ margin: 0, fontSize: '1.5rem', fontWeight: '800', color: '#14b8a6', display: 'flex', alignItems: 'center', gap: '12px' }}>
                        <FiSettings /> Compensation Settings
                    </h1>
                    <p style={{ margin: '8px 0 0 0', color: '#64748b', fontSize: '13px' }}>
                        Configure salary components, revision rules, and document templates
                    </p>
                </div>
                <div style={{ padding: '0 8px 0 8px' }}>
                    {/* Tabs Navigation */}
                    <div style={{ backgroundColor: 'white', borderRadius: '12px', padding: '0 8px', border: '1px solid #f1f5f9', marginBottom: '24px' }}>
                        <div style={tabContainerStyle} className="mobile-scroll">
                            <button
                                style={tabStyle(activeTab === 'salaryStructure')}
                                onClick={() => setActiveTab('salaryStructure')}
                            >
                                <FiDollarSign /> Salary Structure
                            </button>
                            <button
                                style={tabStyle(activeTab === 'revisionTypes')}
                                onClick={() => setActiveTab('revisionTypes')}
                            >
                                <FiTag /> Salary Revision Categories
                            </button>
                            <button
                                style={tabStyle(activeTab === 'designationCategories')}
                                onClick={() => setActiveTab('designationCategories')}
                            >
                                <FiUser /> Designation Categories
                            </button>
                            <button
                                style={tabStyle(activeTab === 'documentTemplates')}
                                onClick={() => setActiveTab('documentTemplates')}
                            >
                                <FiFileText /> Document Templates
                            </button>
                        </div>
                    </div>

                    {/* Tab Content */}
                    <div style={{ backgroundColor: 'white', borderRadius: '12px', padding: '12px', border: '1px solid #f1f5f9' }}>
                        <div style={{ maxWidth: '100%', overflowX: 'auto' }}>
                            {activeTab === 'salaryStructure' && (
                                <SalaryStructureManagement />
                            )}
                        </div>
                    </div>
                </div>
            )}
        </>
    );
};

export default CompensationSettings;
                                <div>
                                    <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '12px' }}>
                                        <FiTag size={18} color="#0d9488" />
                                        <h3 style={{ margin: 0, fontSize: '16px', fontWeight: '700' }}>Salary Revision Categories</h3>
                                    </div>
                                    <p style={{ fontSize: '13px', color: '#64748b', marginBottom: '20px' }}>
                                        Manage different types of salary revisions (e.g., Promotion, Annual Hike, etc.)
                                    </p>

                                    <div style={{ marginBottom: '24px', backgroundColor: '#f8fafc', padding: '20px', borderRadius: '12px', border: '1px solid #e2e8f0' }}>
                                        <div style={{ display: 'flex', gap: '12px', alignItems: 'flex-end', flexWrap: 'wrap' }}>
                                            <div style={{ flex: 1 }}>
                                                <label style={{ ...labelStyle, marginBottom: '6px' }}>Category Name</label>
                                                <input
                                                    type="text"
                                                    placeholder="e.g. Promotion"
                                                    style={{ ...inputStyle, fontSize: '14px', padding: '12px' }}
                                                    value={newRevisionTypeName}
                                                    onChange={(e) => setNewRevisionTypeName(e.target.value)}
                                                    onKeyPress={(e) => e.key === 'Enter' && handleAddRevisionType()}
                                                />
                                            </div>
                                            <button
                                                onClick={handleAddRevisionType}
                                                disabled={isSettingsLoading || !newRevisionTypeName.trim()}
                                                style={{
                                                    padding: '12px 20px',
                                                    backgroundColor: '#0d9488',
                                                    color: 'white',
                                                    border: 'none',
                                                    borderRadius: '8px',
                                                    fontSize: '14px',
                                                    fontWeight: '600',
                                                    cursor: isSettingsLoading || !newRevisionTypeName.trim() ? 'not-allowed' : 'pointer',
                                                    opacity: isSettingsLoading || !newRevisionTypeName.trim() ? 0.5 : 1,
                                                    whiteSpace: 'nowrap',
                                                    width: '100%',
                                                    sm: { width: 'auto' }
                                                }}
                                            >
                                                {isSettingsLoading ? 'Adding...' : 'Add Type'}
                                            </button>
                                        </div>
                                    </div>

                                    <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                                        {revisionTypes.length === 0 ? (
                                            <div style={{ textAlign: 'center', padding: '40px', color: '#94a3b8', backgroundColor: '#f8fafc', borderRadius: '8px', border: '1px solid #e2e8f0' }}>
                                                <FiTag size={48} style={{ marginBottom: '12px', opacity: 0.3 }} />
                                                <p>No revision types found.</p>
                                                <p style={{ fontSize: '12px', marginTop: '4px' }}>Add your first revision type using the form above.</p>
                                            </div>
                                        ) : (
                                            revisionTypes.map((type) => (
                                                <div key={type.id} style={{
                                                    display: 'flex',
                                                    justifyContent: 'space-between',
                                                    alignItems: 'center',
                                                    padding: '12px 16px',
                                                    backgroundColor: 'white',
                                                    border: '1px solid #e2e8f0',
                                                    borderRadius: '8px',
                                                    transition: 'all 0.2s'
                                                }}>
                                                    <div>
                                                        <div style={{ fontSize: '14px', fontWeight: '600', color: '#1e293b' }}>
                                                            {type.typeName}
                                                        </div>
                                                        <div style={{ fontSize: '11px', color: '#64748b', marginTop: '2px' }}>
                                                            ID: {type.id}
                                                        </div>
                                                    </div>
                                                    <button
                                                        onClick={() => handleDeleteRevisionType(type.id)}
                                                        style={{
                                                            background: 'none',
                                                            border: 'none',
                                                            color: '#ef4444',
                                                            fontSize: '12px',
                                                            fontWeight: '600',
                                                            cursor: 'pointer',
                                                            padding: '4px 8px',
                                                            borderRadius: '4px',
                                                            transition: 'all 0.2s'
                                                        }}
                                                        onMouseOver={(e) => {
                                                            e.target.style.backgroundColor = '#fef2f2';
                                                        }}
                                                        onMouseOut={(e) => {
                                                            e.target.style.backgroundColor = 'transparent';
                                                        }}
                                                    >
                                                        Delete
                                                    </button>
                                                </div>
                                            ))
                                        )}
                                    </div>
                                </div>
                            )}

                            {activeTab === 'designationCategories' && (
                                <div>
                                    <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '12px' }}>
                                        <FiUser size={18} color="#0d9488" />
                                        <h3 style={{ margin: 0, fontSize: '16px', fontWeight: '700' }}>Designation Categories</h3>
                                    </div>
                                    <p style={{ fontSize: '13px', color: '#64748b', marginBottom: '20px' }}>
                                        Manage designation categories for proposed designations in salary revisions
                                    </p>

                                    {/* Add New Designation Category */}
                                    <div style={{ marginBottom: '24px', backgroundColor: '#f8fafc', padding: '16px', borderRadius: '12px', border: '1px solid #e2e8f0' }}>
                                        <div style={{ display: 'flex', gap: '12px', alignItems: 'flex-end', flexWrap: 'wrap' }}>
                                            <div style={{ flex: 1, minWidth: '200px' }}>
                                                <label style={{ ...labelStyle, marginBottom: '6px' }}>Category Name</label>
                                                <input
                                                    type="text"
                                                    placeholder="Enter designation category name"
                                                    style={{ ...inputStyle, fontSize: '14px', padding: '12px' }}
                                                    value={newDesignationCategory}
                                                    onChange={(e) => setNewDesignationCategory(e.target.value)}
                                                    onKeyPress={(e) => e.key === 'Enter' && handleAddDesignationCategory()}
                                                />
                                            </div>
                                            <button
                                                onClick={handleAddDesignationCategory}
                                                disabled={isAddingDesignation || !newDesignationCategory.trim()}
                                                style={{
                                                    padding: '12px 20px',
                                                    backgroundColor: '#0d9488',
                                                    color: 'white',
                                                    border: 'none',
                                                    borderRadius: '8px',
                                                    fontSize: '14px',
                                                    fontWeight: '600',
                                                    cursor: isAddingDesignation || !newDesignationCategory.trim() ? 'not-allowed' : 'pointer',
                                                    opacity: isAddingDesignation || !newDesignationCategory.trim() ? 0.5 : 1,
                                                    whiteSpace: 'nowrap',
                                                    width: '100%',
                                                    sm: { width: 'auto' }
                                                }}
                                            >
                                                {isAddingDesignation ? 'Adding...' : 'Add Category'}
                                            </button>
                                        </div>
                                    </div>

                                    {/* Existing Designation Categories */}
                                    <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                                        {designationCategories.length === 0 ? (
                                            <div style={{ textAlign: 'center', padding: '40px', color: '#94a3b8', backgroundColor: '#f8fafc', borderRadius: '8px', border: '1px solid #e2e8f0' }}>
                                                <FiUser size={48} style={{ marginBottom: '12px', opacity: 0.3 }} />
                                                <p>No designation categories found.</p>
                                                <p style={{ fontSize: '12px', marginTop: '4px' }}>Add your first category using the form above.</p>
                                            </div>
                                        ) : (
                                            designationCategories.map((category) => (
                                                <div key={category.id} style={{
                                                    display: 'flex',
                                                    justifyContent: 'space-between',
                                                    alignItems: 'center',
                                                    padding: '12px 16px',
                                                    backgroundColor: 'white',
                                                    border: '1px solid #e2e8f0',
                                                    borderRadius: '8px',
                                                    transition: 'all 0.2s'
                                                }}>
                                                    <div>
                                                        <div style={{ fontSize: '14px', fontWeight: '600', color: '#1e293b' }}>
                                                            {category.name}
                                                        </div>
                                                        <div style={{ fontSize: '11px', color: '#64748b', marginTop: '2px' }}>
                                                            ID: {category.id}
                                                        </div>
                                                    </div>
                                                    <button
                                                        onClick={() => handleDeleteDesignationCategory(category.id)}
                                                        style={{
                                                            background: 'none',
                                                            border: 'none',
                                                            color: '#ef4444',
                                                            fontSize: '12px',
                                                            fontWeight: '600',
                                                            cursor: 'pointer',
                                                            padding: '4px 8px',
                                                            borderRadius: '4px',
                                                            transition: 'all 0.2s'
                                                        }}
                                                        onMouseOver={(e) => {
                                                            e.target.style.backgroundColor = '#fef2f2';
                                                        }}
                                                        onMouseOut={(e) => {
                                                            e.target.style.backgroundColor = 'transparent';
                                                        }}
                                                    >
                                                        Delete
                                                    </button>
                                                </div>
                                            ))
                                        )}
                                    </div>
                                </div>
                            )}

                            {activeTab === 'documentTemplates' && (
                                <div>
                                    <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '12px' }}>
                                        <FiFileText size={18} color="#0d9488" />
                                        <h3 style={{ margin: 0, fontSize: '16px', fontWeight: '700' }}>Document Templates</h3>
                                    </div>
                                    <p style={{ fontSize: '13px', color: '#64748b', marginBottom: '20px' }}>
                                        Manage document templates for compensation letters and notifications
                                    </p>

                                    <div style={{ display: 'flex', flexDirection: 'column', gap: '12px', padding: '12px', borderRadius: '12px', border: '1px solid #e2e8f0', backgroundColor: '#f8fafc' }}>
                                        <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                                            <label style={{ fontSize: '14px', fontWeight: '600', color: '#374151', marginBottom: '4px' }}>
                                                Upload New Template (.docx)
                                            </label>
                                            <div 
                                                onClick={() => templateFileRef.current?.click()}
                                                style={{
                                                    border: '2px dashed #14b8a6',
                                                    borderRadius: '10px',
                                                    padding: '20px',
                                                    backgroundColor: '#f0fdfa',
                                                    textAlign: 'center',
                                                    cursor: 'pointer',
                                                    transition: 'all 0.2s'
                                                }}
                                                onMouseOver={(e) => {
                                                    e.currentTarget.style.backgroundColor = '#ccfbf1';
                                                    e.currentTarget.style.borderColor = '#0d9488';
                                                }}
                                                onMouseOut={(e) => {
                                                    e.currentTarget.style.backgroundColor = '#f0fdfa';
                                                    e.currentTarget.style.borderColor = '#14b8a6';
                                                }}
                                            >
                                                <input 
                                                    ref={templateFileRef}
                                                    type="file" 
                                                    accept=".docx" 
                                                    onChange={(e) => setNewTemplateFile(e.target.files[0])} 
                                                    style={{ display: 'none' }}
                                                />
                                                {newTemplateFile ? (
                                                    <p style={{ margin: 0, fontSize: '14px', color: '#0d9488', fontWeight: '600' }}>
                                                        📄 {newTemplateFile.name}
                                                    </p>
                                                ) : (
                                                    <>
                                                        <p style={{ margin: '0 0 8px 0', fontSize: '24px' }}>📁</p>
                                                        <p style={{ margin: 0, fontSize: '14px', color: '#0f766e', fontWeight: '500' }}>
                                                            Click to select .docx file
                                                        </p>
                                                    </>
                                                )}
                                            </div>
                                        </div>
                                        <button 
                                            onClick={handleUploadTemplate} 
                                            disabled={isSettingsLoading || !newTemplateFile} 
                                            style={{ 
                                                padding: '12px 16px', 
                                                backgroundColor: '#0d9488', 
                                                color: 'white', 
                                                border: 'none', 
                                                borderRadius: '8px', 
                                                fontWeight: '600', 
                                                cursor: 'pointer', 
                                                width: '100%', 
                                                fontSize: '14px',
                                                transition: 'all 0.2s'
                                            }}
                                            onMouseOver={(e) => {
                                                if (!isSettingsLoading && newTemplateFile) {
                                                    e.currentTarget.style.backgroundColor = '#0f766e';
                                                }
                                            }}
                                            onMouseOut={(e) => {
                                                e.currentTarget.style.backgroundColor = '#0d9488';
                                            }}
                                        >
                                            {isSettingsLoading ? 'Uploading...' : 'Upload Template'}
                                        </button>
                                    </div>

                                    <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }} className="mobile-scroll">
                                        {templates.length === 0 ? (
                                            <div style={{ textAlign: 'center', padding: '32px 16px', color: '#94a3b8', backgroundColor: '#f8fafc', borderRadius: '8px', border: '1px solid #e2e8f0' }}>
                                                <FiFileText size={40} style={{ marginBottom: '12px', opacity: 0.3 }} />
                                                <p style={{ fontSize: '14px', margin: '0 0 4px 0' }}>No templates found.</p>
                                                <p style={{ fontSize: '12px', margin: 0, opacity: 0.8 }}>Upload your first template using the form above.</p>
                                            </div>
                                        ) : (
                                            templates.map((tmp) => (
                                                <div key={tmp.id} style={{
                                                    display: 'flex',
                                                    justifyContent: 'space-between',
                                                    alignItems: 'center',
                                                    padding: '12px',
                                                    backgroundColor: 'white',
                                                    border: '1px solid #e2e8f0',
                                                    borderRadius: '8px',
                                                    transition: 'all 0.2s',
                                                    gap: '12px',
                                                    flexWrap: 'wrap'
                                                }}>
                                                    <div>
                                                        <div style={{ fontSize: '14px', fontWeight: '600', color: '#1e293b' }}>
                                                            {tmp.templateName}
                                                        </div>
                                                        <div style={{ fontSize: '11px', color: '#64748b', marginTop: '2px' }}>
                                                            {tmp.category} • ID: {tmp.id}
                                                        </div>
                                                    </div>
                                                    <div style={{ display: 'flex', gap: '8px', flexDirection: 'column', sm: { flexDirection: 'row' }, alignItems: 'stretch', minWidth: '140px', flexShrink: 0 }}>
                                                        <button
                                                            onClick={() => handlePreviewTemplate(tmp.id, tmp.templateName)}
                                                            style={{
                                                                background: 'none',
                                                                border: '1px solid #3b82f6',
                                                                color: '#3b82f6',
                                                                fontSize: '12px',
                                                                fontWeight: '600',
                                                                cursor: 'pointer',
                                                                padding: '8px 12px',
                                                                borderRadius: '6px',
                                                                transition: 'all 0.2s',
                                                                flex: 1,
                                                                textAlign: 'center',
                                                                minWidth: '60px'
                                                            }}
                                                            onMouseOver={(e) => {
                                                                e.target.style.backgroundColor = '#eff6ff';
                                                            }}
                                                            onMouseOut={(e) => {
                                                                e.target.style.backgroundColor = 'transparent';
                                                            }}
                                                        >
                                                            Preview
                                                        </button>
                                                        <button
                                                            onClick={() => handleDeleteTemplate(tmp.id)}
                                                            style={{
                                                                background: 'none',
                                                                border: '1px solid #ef4444',
                                                                color: '#ef4444',
                                                                fontSize: '12px',
                                                                fontWeight: '600',
                                                                cursor: 'pointer',
                                                                padding: '8px 12px',
                                                                borderRadius: '6px',
                                                                transition: 'all 0.2s',
                                                                flex: 1,
                                                                textAlign: 'center',
                                                                minWidth: '60px'
                                                            }}
                                                            onMouseOver={(e) => {
                                                                e.target.style.backgroundColor = '#fef2f2';
                                                            }}
                                                            onMouseOut={(e) => {
                                                                e.target.style.backgroundColor = 'transparent';
                                                            }}
                                                        >
                                                            Delete
                                                        </button>
                                                    </div>
                                                </div>
                                            ))
                                        )}
                                    </div>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            </div>

            {/* Delete confirmation now uses browser confirm() dialog */}

            {/* Template Preview Modal */}
            {previewModal.isOpen && (
                <div style={{
                    position: 'fixed',
                    top: 0,
                    left: 0,
                    right: 0,
                    bottom: 0,
                    backgroundColor: 'rgba(0, 0, 0, 0.75)',
                    display: 'flex',
                    justifyContent: 'center',
                    alignItems: 'center',
                    zIndex: 10001
                }}>
                    <div style={{
                        backgroundColor: 'white',
                        borderRadius: '12px',
                        width: '95%',
                        maxWidth: '1200px',
                        height: '85%',
                        maxHeight: '800px',
                        display: 'flex',
                        flexDirection: 'column',
                        boxShadow: '0 25px 50px -12px rgba(0, 0, 0, 0.25)',
                        overflow: 'hidden'
                    }}>
                        {/* Modal Header */}
                        <div style={{
                            padding: '16px 20px',
                            borderBottom: '1px solid #e2e8f0',
                            display: 'flex',
                            justifyContent: 'space-between',
                            alignItems: 'center',
                            backgroundColor: '#f8fafc',
                            flexShrink: 0
                        }}>
                            <div>
                                <h3 style={{ margin: 0, fontSize: '1.25rem', color: '#1e293b', fontWeight: '600' }}>
                                    Template Preview: {previewModal.template?.name}
                                </h3>
                                <p style={{ margin: '4px 0 0 0', fontSize: '0.875rem', color: '#64748b' }}>
                                    Microsoft Word Document (.docx)
                                </p>
                            </div>
                            <button
                                onClick={handleClosePreviewModal}
                                style={{
                                    background: 'none',
                                    border: 'none',
                                    cursor: 'pointer',
                                    color: '#64748b',
                                    padding: '8px',
                                    borderRadius: '50%',
                                    display: 'flex',
                                    alignItems: 'center',
                                    justifyContent: 'center',
                                    transition: 'all 0.2s',
                                }}
                                onMouseOver={(e) => {
                                    e.currentTarget.style.backgroundColor = '#e2e8f0';
                                    e.currentTarget.style.color = '#ef4444';
                                }}
                                onMouseOut={(e) => {
                                    e.currentTarget.style.backgroundColor = 'transparent';
                                    e.currentTarget.style.color = '#64748b';
                                }}
                                title="Close Preview"
                            >
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                        </div>

                        {/* Modal Body */}
                        <div style={{
                            flex: 1,
                            padding: '0',
                            backgroundColor: '#f8fafc',
                            display: 'flex',
                            flexDirection: 'column',
                            overflow: 'hidden'
                        }}>
                            {isDocumentLoading ? (
                                <div style={{
                                    display: 'flex',
                                    flexDirection: 'column',
                                    alignItems: 'center',
                                    justifyContent: 'center',
                                    height: '100%',
                                    padding: '40px'
                                }}>
                                    <div style={{
                                        width: '40px',
                                        height: '40px',
                                        border: '4px solid #e2e8f0',
                                        borderTop: '4px solid #0d9488',
                                        borderRadius: '50%',
                                        animation: 'spin 1s linear infinite',
                                        marginBottom: '16px'
                                    }}></div>
                                    <p style={{ margin: 0, color: '#64748b', fontSize: '0.875rem' }}>
                                        Loading document content...
                                    </p>
                                </div>
                            ) : documentContent ? (
                                <div style={{
                                    flex: 1,
                                    overflow: 'auto',
                                    padding: '24px',
                                    backgroundColor: 'white'
                                }}>
                                    <div style={{
                                        maxWidth: '800px',
                                        margin: '0 auto',
                                        backgroundColor: 'white',
                                        padding: '40px',
                                        border: '1px solid #e2e8f0',
                                        borderRadius: '8px',
                                        boxShadow: '0 1px 3px 0 rgba(0, 0, 0, 0.1)',
                                        lineHeight: '1.6',
                                        color: '#374151',
                                        fontSize: '14px'
                                    }}>
                                        <div 
                                            dangerouslySetInnerHTML={{
                                                __html: `
                                                    <style>
                                                        table {
                                                            width: 100%;
                                                            border-collapse: collapse;
                                                            margin-bottom: 1em;
                                                            font-family: Arial, sans-serif;
                                                        }
                                                        th, td {
                                                            border: 1px solid #e2e8f0;
                                                            padding: 8px 12px;
                                                            text-align: left;
                                                            vertical-align: top;
                                                        }
                                                        th {
                                                            background-color: #f8fafc;
                                                            font-weight: bold;
                                                            color: #374151;
                                                        }
                                                        tr:nth-child(even) {
                                                            background-color: #f9fafb;
                                                        }
                                                        p {
                                                            margin: 0.5em 0;
                                                            line-height: 1.5;
                                                        }
                                                        h1, h2, h3, h4, h5, h6 {
                                                            color: #1f2937;
                                                            margin: 1em 0 0.5em 0;
                                                        }
                                                    </style>
                                                    ${documentContent.html}
                                                `
                                            }}
                                            style={{
                                                minHeight: '200px'
                                            }}
                                        />
                                    </div>
                                </div>
                            ) : (
                                <div style={{
                                    display: 'flex',
                                    flexDirection: 'column',
                                    alignItems: 'center',
                                    justifyContent: 'center',
                                    height: '100%',
                                    padding: '40px'
                                }}>
                                    <div style={{
                                        width: '80px',
                                        height: '80px',
                                        backgroundColor: '#3b82f6',
                                        borderRadius: '50%',
                                        display: 'flex',
                                        alignItems: 'center',
                                        justifyContent: 'center',
                                        margin: '0 auto 20px auto'
                                    }}>
                                        <svg width="40" height="40" viewBox="0 0 24 24" fill="white">
                                            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                                            <polyline points="14,2 14,8 20,8" fill="none" stroke="white" strokeWidth="2"/>
                                            <line x1="16" y1="13" x2="8" y2="13" stroke="white" strokeWidth="2"/>
                                            <line x1="16" y1="17" x2="8" y2="17" stroke="white" strokeWidth="2"/>
                                            <polyline points="10,9 9,9 8,9" fill="none" stroke="white" strokeWidth="2"/>
                                        </svg>
                                    </div>
                                    <h4 style={{ margin: '0 0 12px 0', fontSize: '1.125rem', color: '#1e293b', fontWeight: '600' }}>
                                        Document Preview Unavailable
                                    </h4>
                                    <p style={{ margin: '0 0 24px 0', fontSize: '0.875rem', color: '#64748b', lineHeight: '1.5', textAlign: 'center', maxWidth: '400px' }}>
                                        This document format cannot be displayed directly in the browser. Please use one of the options below to view the template.
                                    </p>
                                    <div style={{ display: 'flex', gap: '12px', justifyContent: 'center', flexWrap: 'wrap' }}>
                                        <button
                                            onClick={() => {
                                                const link = document.createElement('a');
                                                link.href = previewModal.fileUrl;
                                                link.download = `${previewModal.template?.name}.docx`;
                                                document.body.appendChild(link);
                                                link.click();
                                                document.body.removeChild(link);
                                            }}
                                            style={{
                                                padding: '12px 24px',
                                                backgroundColor: '#0d9488',
                                                color: 'white',
                                                border: 'none',
                                                borderRadius: '8px',
                                                fontWeight: '600',
                                                cursor: 'pointer',
                                                fontSize: '0.875rem',
                                                display: 'flex',
                                                alignItems: 'center',
                                                gap: '8px',
                                                transition: 'background-color 0.2s'
                                            }}
                                            onMouseOver={(e) => e.currentTarget.style.backgroundColor = '#0f766e'}
                                            onMouseOut={(e) => e.currentTarget.style.backgroundColor = '#0d9488'}
                                        >
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                                <polyline points="7,10 12,15 17,10"/>
                                                <line x1="12" y1="15" x2="12" y2="3"/>
                                            </svg>
                                            Download & Open in Word
                                        </button>
                                        <button
                                            onClick={() => {
                                                window.open(previewModal.fileUrl, '_blank');
                                            }}
                                            style={{
                                                padding: '12px 24px',
                                                backgroundColor: '#3b82f6',
                                                color: 'white',
                                                border: 'none',
                                                borderRadius: '8px',
                                                fontWeight: '600',
                                                cursor: 'pointer',
                                                fontSize: '0.875rem',
                                                display: 'flex',
                                                alignItems: 'center',
                                                gap: '8px',
                                                transition: 'background-color 0.2s'
                                            }}
                                            onMouseOver={(e) => e.currentTarget.style.backgroundColor = '#2563eb'}
                                            onMouseOut={(e) => e.currentTarget.style.backgroundColor = '#3b82f6'}
                                        >
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                                <circle cx="12" cy="12" r="3"/>
                                            </svg>
                                            Open in Browser
                                        </button>
                                    </div>
                                    <p style={{ margin: '16px 0 0 0', fontSize: '0.75rem', color: '#94a3b8', textAlign: 'center' }}>
                                        💡 Tip: For best results, download the file and open it in Microsoft Word
                                    </p>
                                </div>
                            )}
                        </div>

                        {/* Modal Footer */}
                        <div style={{
                            padding: '16px 24px',
                            borderTop: '1px solid #e2e8f0',
                            display: 'flex',
                            justifyContent: 'flex-end',
                            backgroundColor: 'white'
                        }}>
                            <button
                                onClick={handleClosePreviewModal}
                                style={{
                                    padding: '10px 20px',
                                    backgroundColor: '#1e293b',
                                    color: 'white',
                                    border: 'none',
                                    borderRadius: '6px',
                                    cursor: 'pointer',
                                    fontWeight: '500',
                                    fontSize: '0.875rem',
                                    transition: 'background-color 0.2s'
                                }}
                                onMouseOver={(e) => e.currentTarget.style.backgroundColor = '#334155'}
                                onMouseOut={(e) => e.currentTarget.style.backgroundColor = '#1e293b'}
                            >
                                Close Preview
                            </button>
                        </div>
                    </div>
                </div>
            )}
        </>
    );
};

export default CompensationSettings;
